# Database - Get these from Supabase or Neon (free tier)
# Supabase: Project Settings > Database > Connection string
# Neon: Dashboard > Connection Details
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth - CHANGE THE SECRET before deploying
NEXTAUTH_SECRET="change-this-to-a-long-random-string-in-production"
NEXTAUTH_URL="http://localhost:3000"

# SMS Provider (configure when ready)
SMS_PROVIDER="hubtel"
SMS_API_KEY=""
SMS_API_SECRET=""
SMS_SENDER_ID="WWA"
